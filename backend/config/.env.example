# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8765
DEBUG_MODE=True

# LLM Configuration (groq or ollama)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat

# Whisper Configuration
WHISPER_MODEL=base
USE_GPU=False

# Audio Configuration
SAMPLE_RATE=16000
CHUNK_SIZE=1024
WAKE_WORD=jarvis
WAKE_WORD_THRESHOLD=0.5

# WhatsApp Automation
WHATSAPP_HEADLESS=True
WHATSAPP_TIMEOUT=30
WHATSAPP_CONTACTS_FILE=backend/config/contacts.json

# Text-to-Speech
USE_TEXT_TO_SPEECH=True
TTS_VOICE=HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Speech\\Voices\\Tokens\\TTS_MS_EN-US_ZIRA_11.0
TTS_SPEED=150

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# System Commands
ENABLE_SYSTEM_COMMANDS=True

# Response Timeout
JARVIS_RESPONSE_TIMEOUT=30

# WebSocket
WEBSOCKET_MAX_SIZE=10485760
WEBSOCKET_PING_INTERVAL=20
WEBSOCKET_PING_TIMEOUT=10
